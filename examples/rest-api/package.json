{
  "name": "rest-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/main.js\"",
    "build": "tsup",
    "start": "node dist/main.js",
    "check-types": "tsc --noEmit",
    "lint": "echo 'add lint script'",
    "test": "vitest run",
    "test:integration": "docker compose up -d mongodb && vitest run --config vitest.integration.config.ts && docker compose down",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker -compose logs -f",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hipponot/soa-core-api": "0.0.2",
    "@hipponot/soa-db": "0.0.1",
    "@hipponot/soa-logger": "0.0.2",
    "express": "^4.18.2",
    "figlet": "^1.8.1",
    "inversify": "^6.2.2",
    "mongodb": "^6.10.0",
    "pino-pretty": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.2",
    "snappy": "^7.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^1.5.0"
  }
}