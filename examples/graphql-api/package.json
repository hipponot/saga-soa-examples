{
  "name": "graphql-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/main.js\"",
    "build": "tsup",
    "start": "node dist/main.js",
    "check-types": "tsc --noEmit",
    "lint": "echo 'add lint script'",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "emit-schema": "tsx scripts/emit-schema.ts"
  },
  "dependencies": {
    "@hipponot/soa-core-api": "1.0.0",
    "@hipponot/soa-db": "1.0.0",
    "@hipponot/soa-logger": "1.0.0",
    "class-validator": "^0.14.1",
    "graphql": "^16.9.0",
    "inversify": "^6.2.2",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.0.0",
    "vitest": "^1.5.0"
  }
}